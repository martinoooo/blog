{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2022",
    "lib": ["es2022"],
    "outDir": "./dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "removeComments": true,
    "baseUrl": "./",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true
  },
  "exclude": ["node_modules", "dist"]
}
